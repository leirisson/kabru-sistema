generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url é definida em prisma.config.ts (Prisma 7+). Não adicionar url aqui.
}

model Usuario {
  id                  String            @id @default(uuid())
  nome                String
  email               String            @unique
  senhaHash           String
  role                Role
  createdAt           DateTime          @default(now())
  historicos          HistoricoStatus[]
  pedidosComoVendedor Pedido[]          @relation("Vendedor")
  permissao           PermissaoUsuario?
}

model Cliente {
  id                String   @id @default(uuid())
  razaoSocial       String
  nomeFantasia      String?
  cnpj              String   @unique
  inscricaoEstadual String?
  telefone          String?
  email             String?
  endereco          String?
  bairro            String?
  cep               String?
  cidade            String?
  estado            String?
  pedidos           Pedido[]
}

model Produto {
  id        String       @id @default(uuid())
  codigo    String       @unique
  descricao String
  unidade   String
  itens     ItemPedido[]
}

model Pedido {
  id                String            @id @default(uuid())
  numero            Int               @unique
  clienteId         String
  vendedorId        String
  condicaoPagamento String
  dataEmissao       DateTime
  valorTotal        Decimal
  statusAtual       StatusPedido      @default(AGUARDANDO_SEPARACAO)
  createdAt         DateTime          @default(now())
  historico         HistoricoStatus[]
  itens             ItemPedido[]
  cliente           Cliente           @relation(fields: [clienteId], references: [id])
  vendedor          Usuario           @relation("Vendedor", fields: [vendedorId], references: [id])
}

model ItemPedido {
  id           String  @id @default(uuid())
  pedidoId     String
  produtoId    String
  quantidade   Int
  precoLiquido Decimal
  subtotal     Decimal
  pedido       Pedido  @relation(fields: [pedidoId], references: [id])
  produto      Produto @relation(fields: [produtoId], references: [id])
}

model HistoricoStatus {
  id         String       @id @default(uuid())
  pedidoId   String
  status     StatusPedido
  usuarioId  String
  observacao String?
  criadoEm   DateTime     @default(now())
  pedido     Pedido       @relation(fields: [pedidoId], references: [id])
  usuario    Usuario      @relation(fields: [usuarioId], references: [id])
}

model SlaConfig {
  status         StatusPedido @id
  avisoMinutos   Int
  criticoMinutos Int
}

model PermissaoRole {
  role            Role     @id
  podeAvancarPara String[]
  rotasPermitidas String[]
}

model PermissaoUsuario {
  usuarioId       String   @id
  podeAvancarPara String[]
  rotasPermitidas String[]
  usuario         Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  VENDEDOR
  ESTOQUE
  CONFERENCIA
  FATURAMENTO
  EXPEDICAO
}

enum StatusPedido {
  AGUARDANDO_SEPARACAO
  SEPARACAO
  CONFERENCIA
  CONFERIDO
  FATURAMENTO
  SEPARACAO_DESTINATARIO
  CONCLUIDO
}
